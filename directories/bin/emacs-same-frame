#!/usr/bin/env bash
#Maintained in linux-config.org
emacsclient -s "general" -e "(if (> (length (frame-list)) 1) 't)" | grep -q t
if [ "$?" = 0 ]; then
    # echo "emacs frame found"
    sway-notify "found emacs frame"
    emacsclient -s "general"  -n  "$@"
else
    # echo "emacs frame NOT found"
    exists=$(pidof "emacs")
    emacsclient -s "general" -n -c "$@"
    [ -z "$exists" ] && sleep 7 || sleep 0.5
fi
sway-do-tool "emacs-general"
