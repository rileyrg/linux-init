#!/usr/bin/env bash
# Maintained in linux-config.org
if [ -d ~/hetzner ]; then
    umount ~/hetzner
    rmdir ~/hetzner
    echo "Closed ~/hetzner"
else
    mkdir -p ~/hetzner
    rclone mount $( [ ! "$1" = "rw" ] && echo "--read-only") hetzner: ~/hetzner &> /dev/null &
    echo "Mounted ~/hetzner"
fi
