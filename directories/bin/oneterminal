#!/usr/bin/bash
#Maintained in linux-init-files.org
sessionname="${1:-TERM}"
scriptname="${2}"
WID=`xdotool search --name "^${sessionname}$" | head -1`
if [ -z "$WID" ]; then
    echo "No window called $sessionname exists so we try to create one.."
    if [ -z "$scriptname" ]; then
        echo "No specific script passed in so we'll default to trying a script called $sessionname".
        scriptname="$sessionname"
    fi
    if command -v "$scriptname" &> /dev/null; then
        script="$scriptname"
    else
        echo "No valid script to configure the session so just use a default session."
        script="tmux new-session -A -s "$sessionname""
    fi
    terminator --title="$sessionname" --profile="$(hostname)" -e "$script"
else
    echo "Found a window called $sessionname so jumping to it..."
    xdotool windowactivate $WID
fi
