#!/usr/bin/bash
#Maintained in linux-init-files.org
sessionname="${1:-OneTerminal}"
script="${2}"
WID=`xdotool search --name "^${sessionname}$" | head -1`
created=0
if [ -z "$WID" ]; then
    terminator -T "${sessionname}" -p "${sessionname}" -e "tmux new-session -A -s ${sessionname} ${script}"
else
    echo "Found a window called $sessionname so jumping to it..."
    xdotool windowactivate $WID
    exit 1
fi
