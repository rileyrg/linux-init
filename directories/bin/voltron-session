#!/usr/bin/bash
# Maintained in linux-init-files.org
session="${1:-voltron}"
window="${2:-"0"}"
pane="${3:-"0"}"
if ! tmux has-session -t "${session}" &> /dev/null; then
    tmux new-session -c "${TMUX_DIR:-"."}" -d -s "${session}" &> /dev/null
    TMUX_DIR="~/development/projects/C/emacs/" voltron-panes-h "${session}" "${window}" "${pane}"
fi
echo "${session}"
