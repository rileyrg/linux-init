#!/usr/bin/bash
# Maintained in linux-init-files.org
systemctl --user start  pulseaudio &> /dev/null || true

xidlehook \
    `# Don't lock when there's a fullscreen application` \
    --not-when-fullscreen \
    `# Don't lock when there's audio playing` \
    --not-when-audio \
    --timer ${XIDLEHOOK_KBD:-15}\
    'pre-blank' \
    'post-blank' \
    --timer ${XIDLEHOOK_DIM:-120}\
    'xbacklight -set 5' \
    'post-blank' \
    --timer ${XIDLEHOOK_BLANK:-120}\
    'xbacklight -set 0' \
    'post-blank' \
    --timer ${XIDLEHOOK_LOCK:-300}\
    'pre-lock && xset dpms force standby' \
    'post-blank && post-lock' \
    --timer ${XIDLEHOOK_SUSPEND:-3600}\
    'systemctl suspend' \
    ''
