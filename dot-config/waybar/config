{
  "layer": "top",
  "position": "top",
  "height": 10,
  "width": 0,

  "modules-left": [
    "sway/workspaces",
    "cpu",
    "temperature",
    "memory"
  ],

  "modules-center": [
    "custom/weather",
    "custom/clock",
    "idle_inhibitor",
    "custom/monitors"
  ],

  "modules-right": [
    "pulseaudio",
    "backlight",
    "battery",
    "custom/power-draw",
    "wlr/taskbar",
    "tray"
  ],

  "network": {
    "format-wifi": "<span color='#589df6'>яЗл</span> <span color='gray'>{signalStrength}%</span>" ,
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} яЮЦ",
    "format-linked": "{ifname} (No IP) яЮЦ",
    "format-disconnected": "яЗл яДз",
    "format-alt": "<span color='gray'>{essid}</span> <span color='green'>тмЗ</span>{bandwidthDownBits} <span color='green'>тмЖ</span>{bandwidthUpBits}",
    "interval": 60,
    "tooltip-format": "{ifname} яВй {ipaddr}"
  },


  "sway/workspaces": {

    "persistant_workspaces": {
       "edit": [],
       "research": [],
       "IDE": [],
       "DEBUG": [],
    },


    "disable-scroll": true,
    "all-outputs": false,
    "format": "{index} {name}",
    "format-icons": {
      "urgent": "<span color='#e85c5c'>яБк</span>",
      "focused": "<span color='#8af0f0'>яЖТ</span>",
      "default": "<span color='#b8b8b8'>яДС</span>"
    }
  },

  "sway/mode": {
    "format": "{}"
  },

  "backlight": {
    //		"device": "acpi_video1",
    "format": "{icon} {percent}%",
    "format-icons": ["ЁЯФЕ", "ЁЯФЖ"]
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 20,
      "critical": 10
    },
    "format": "<span color='gold'>{icon}</span> {capacity}%",

    "format-charging": "<span color='gold'>яЧз </span> {capacity}% ({time})",
    "format-plugged":  "<span color='gold'>{icon} яЗж </span> {capacity}%",
    //		"format-good": "", // An empty format will hide the module
    "format-discharging": "<span color='yellow'>{icon}</span> {capacity}% ({time})",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
    "on-click" : "sway-htop"
  },

  "custom/clock": {
    "interval": 60,
    "exec": "date +'%a, %d %b: %H:%M'",
    "format": "{} ",
    "max-length": 25
  },

  "cpu": {
    "interval": 5,
    "format": "<span color='#eb8a60'>яЛЫ {usage}% ({load})</span>",
    "states": {
      "warning": 70,
      "critical": 90
    },
    "on-click" : "hardinfo"
  },

  "idle_inhibitor": {
    "format": "<span color='GOLD'>{icon}</span>",
    "format-icons": {
      "activated": "ЁЯУАя░М",
      "deactivated": "ЁЯШ┤яИ╢"
    },
    "on-click-right": "sway-lock"
  },
  "pulseaudio": {
    "format": "{icon} {volume}% {format_source}",
    "format-muted": "ЁЯФЗ {format_source}",
    "format-bluetooth": "{icon}яКФ {volume}% {format_source}",
    "format-bluetooth-muted": "ЁЯФЗяКФ {format_source}",

    "format-source": "яД░ {volume}%",
    "format-source-muted": "яД▒",

    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["ЁЯФИ", "ЁЯФЙ", "ЁЯФК"]
    },
    "on-click": "pulse-volume toggle",
    "on-click-right": "pavucontrol"
  },

  "tray": {
    "icon-size": 21,
    "spacing": 5
  },

  "custom/weather": {
    "format": "{} ",
    "tooltip": true,
    "interval": 3600,
    "exec": "waybar-weather-json",
    "return-type": "json"
  },

  "custom/uptime": {
    "format": "<span color='white'>тМЫ{}</span>",
    "interval": 60,
    "exec": "uptime -p"
  },

  "custom/dropbox": {
    "format": "яЕл<span color='gold'>{}</span>",
    "return-type" : "json",
    "interval": 5,
    "exec": "waybar-dropbox-json",
    "tooltip": "true",
    "on-click": "dropbox start && sway-notify 'Restarting Dropbox.'",
    "on-click-right": "sway-www https://www.dropbox.com/h"
  },
  "custom/monitors": {
    "format": "<span color='gold'>{}</span>",
    "return-type" : "json",
    "interval": 10,
    "exec": "waybar-monitors",
    "tooltip": "true",
    "on-click": "sway-screen-menu"
  },
  "custom/bluetooth": {
    "format": "<span color='blue'>яКФ{}</span>",
    "interval": 30,
    "exec": "waybar-bluetooth",
    "tooltip": "false",
    "on-click": "sway-bluetooth"
  },
  "custom/power-draw": {
    "format": "<span color='gold'>тЪб{}ЁЯФЛ</span>",
    "interval": 5,
    "exec": "waybar-power-draw",
    "tooltip": "false"
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 14,
    "icon-theme": "Numix-Circle",
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close"
  },

  "custom/mynetwork": {
    "format":  "{}",
    "format-wifi":  "ЁЯУ╢{ssid}",
    "format-ipaddr": "{ipaddr}",
    "format-ssid": "xx{ssid}xx",
    "format-alt": "{alt}:{}",
    "exec": "waybar-ip-info-json",
    "return-type": "json",
    "interval": 60,
    "on-click-right": "sway-wifi",
    "tooltip-format": "{ssid}",
    "tooltip": "true"
  }

}
